{
  "name": "@moj-bichard7-developers/bichard7-next-core",
  "version": "1.0.1",
  "description": "The code to replace the processing logic of Bichard 7",
  "main": "build/index.js",
  "scripts": {
    "build:lambda:prod": "npx webpack --config ./.webpack/webpack.prod.js",
    "build:lambda:dev": "npm run clean && webpack --config ./.webpack/webpack.dev.js",
    "test": "jest --maxWorkers=2 --testPathIgnorePatterns='comparison.test|integration.test' --testNamePattern=",
    "test:update": "jest -u --testPathIgnorePatterns='comparison.test|integration.test' 'integration.test'",
    "test:bichard": "USE_BICHARD=true jest --runInBand --testPathIgnorePatterns='comparison.test|integration.test' --testNamePattern=",
    "test:watch": "jest --watch --testPathIgnorePatterns='comparison.test|integration.test'",
    "test:compare": "jest --testPathPattern=comparison.test",
    "test:integration": "jest --runInBand --testPathPattern=integration.test",
    "test:server": "NODE_ENV=test ts-node scripts/testServer.ts",
    "clean": "rimraf build",
    "compare": "TS_NODE_TRANSPILE_ONLY=true ts-node src/comparison/cli.ts",
    "compare:dev": "npm run compare | pino-pretty",
    "build": "npm run clean && tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky install",
    "update-deps": "ncu -u && npm install",
    "postinstall": "./scripts/install-standing-data.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ministryofjustice/bichard7-next-core.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ministryofjustice/bichard7-next-core/issues"
  },
  "homepage": "https://github.com/ministryofjustice/bichard7-next-core#readme",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.18.9",
    "@babel/preset-typescript": "^7.18.6",
    "@types/diff": "^5.0.2",
    "@types/express": "^4.17.13",
    "@types/jest": "^28.1.6",
    "@types/lodash.differencewith": "^4.5.7",
    "@types/lodash.isequal": "^4.5.6",
    "@types/lodash.merge": "^4.6.7",
